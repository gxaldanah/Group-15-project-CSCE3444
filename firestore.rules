rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidStats(stats) {
      return stats is map
        && stats.keys().hasOnly(['strength', 'intelligence', 'charisma', 'agility', 'luck'])
        && stats.strength is number && stats.strength >= 0 && stats.strength <= 20
        && stats.intelligence is number && stats.intelligence >= 0 && stats.intelligence <= 20
        && stats.charisma is number && stats.charisma >= 0 && stats.charisma <= 20
        && stats.agility is number && stats.agility >= 0 && stats.agility <= 20
        && stats.luck is number && stats.luck >= 0 && stats.luck <= 20;
    }

    function isValidChoiceStyleProfile(profile) {
      return profile is map
        && profile.keys().hasOnly(['bold', 'careful'])
        && profile.bold is number && profile.bold >= 0 && profile.bold <= 10
        && profile.careful is number && profile.careful >= 0 && profile.careful <= 10;
    }

    function isValidChapterSceneId(chapterSceneId) {
      return chapterSceneId is string
        && chapterSceneId.size() > 0
        && chapterSceneId.size() <= 40
        && (
          chapterSceneId.matches('^chapter([1-9]|10)_start$')
          || chapterSceneId == 'ending'
          || chapterSceneId in ['arrival', 'villageNow', 'observe']
        );
    }

    function isValidGameProgress(data) {
      return hasOnlyAllowedFields(['screen', 'selectedCharacterId', 'pointsLeft', 'chapterSceneId', 'choiceStyleProfile', 'stats', 'updatedAt'])
        && data.screen is string
        && data.screen in ['points', 'nextScreen']
        && data.selectedCharacterId is string
        && data.selectedCharacterId.size() > 0
        && data.pointsLeft is number
        && data.pointsLeft >= 0
        && data.pointsLeft <= 20
        && isValidChapterSceneId(data.chapterSceneId)
        && isValidChoiceStyleProfile(data.choiceStyleProfile)
        && isValidStats(data.stats)
        && data.updatedAt is timestamp
        && data.updatedAt <= request.time
        && data.updatedAt > request.time - duration.value(5, 'm');
    }

    match /gameProgress/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidGameProgress(request.resource.data);
      allow update: if isOwner(userId) && isValidGameProgress(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
